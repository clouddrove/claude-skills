# Version control
.git
.gitignore

# macOS
.DS_Store

# Editor swap/backup files
*.swp
*.bak
*.tmp
*~

# IDE directories
.idea/
.vscode/

# Python artifacts
__pycache__/
*.pyc

# Packaged Helm charts (avoid nesting .tgz inside a chart)
*.tgz

# CI/CD configuration
.github/
.gitlab-ci.yml
.circleci/

# Documentation and project files (not needed at runtime)
tests/
docs/
README.md
CHANGELOG.md
LICENSE
